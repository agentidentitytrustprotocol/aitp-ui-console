# Playground (Python FastAPI)
PLAYGROUND_URL=http://localhost:8000
PLAYGROUND_API_KEY=

# Control Plane (Next.js)
CP_URL=http://localhost:4000
CP_API_KEY=

# CSRF guard — comma-separated extra Origins to allow on mutation routes.
# Same-origin requests (Origin host matches request Host) and requests
# without an Origin header (curl, server-to-server) are always allowed.
# Add an entry when the console runs behind a reverse proxy or on a
# different external origin than the internal Host header, e.g.:
#   TRUSTED_ORIGINS=https://console.example.com,https://console-staging.example.com
TRUSTED_ORIGINS=
